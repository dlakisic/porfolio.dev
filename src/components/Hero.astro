---
const personalImageAlt = "Dino Lakisic"
import Badge from "@/components/Badge.astro"
import LinkedInIcon from "@/components/icons/LinkedIn.astro"
import MailIcon from "@/components/icons/Mail.astro"
import GitHub from "@/components/icons/GitHub.astro"
import LinkButton from "@/components/LinkButton.astro"
import Python from "./icons/Python.astro"
import PostgreSQL from "./icons/PostgreSQL.astro"
import Docker from "./icons/Docker.astro"
---

<div class="max-w-xl">
  <div class="flex gap-4 mb-4">
    <img
      class="rounded-full shadow-lg size-16"
      src="/Dino.webp"
      alt={personalImageAlt}
    />
    <a
      href="https://linkedin.com/in/dino-lakisic"
      target="_blank"
      rel="noopener"
      class="flex items-center transition md:justify-center md:hover:scale-105"
    >
      <Badge>Disponible pour de nouvelles opportunités</Badge>
    </a>
  </div>
  <h1
    class="text-4xl font-bold tracking-tight text-gray-800 sm:text-5xl dark:text-white"
  >
    Hey, moi c'est Dino
  </h1>
  <p
    class="mt-6 text-xl text-gray-800 dark:[&>strong]:text-yellow-200 [&>strong]:text-yellow-500 [&>strong]:font-semibold dark:text-gray-300"
  >
    +15 años de experiencia. <strong
      >AI Engineer</strong
    > Basé à Rennes, France 🇫🇷. Mon rôle est d'optimiser votre business grâce à l'IA.
  </p>
  <nav class="flex flex-wrap gap-4 mt-8">
    <LinkButton href="https://linkedin.com/in/dino-lakisic">
      <LinkedInIcon class="size-1000000" />
      LinkedIn
    </LinkButton>
    <LinkButton href="https://github.com/dlakisic">
      <GitHub class="size-1000000" />
      Github
    <LinkButton href="mailto:dino@lakisic.dev">
      <MailIcon class="size-1000000" />
      Me contacter
    </LinkButton>
  </nav>
  <nav class="flex flex-wrap gap-4 mt-8">
    <LinkButton>
      <Python class="size-7" />
      Python
    </LinkButton>
    <LinkButton>
      <PostgreSQL class="size-4" />
      PostgreSQL
    <LinkButton>
      <Docker class="size-5" />
      Docker
    </LinkButton>
  </nav>
</div>
